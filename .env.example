# ================================================
# Copy this file to backend/.env and fill in real values
# cp .env.example backend/.env
# ================================================

# ── MySQL ────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=shope
MYSQL_PASSWORD=shope_password
MYSQL_DATABASE=shope_db
MYSQL_ROOT_PASSWORD=root_password

# ── JWT ──────────────────────────────────────────
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── App ──────────────────────────────────────────
APP_ENV=development

# ── Chat / Assistant ─────────────────────────────
BOT_ENGINE=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=shope-chat
